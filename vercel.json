{
  "version": 2,
  "builds": [
    {
      "src": "masroofy/masroofy/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.9" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "masroofy/masroofy/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "masroofy.settings"
  }
}