{
  "version": 2,
  "builds": [
    {
      "src": "masroofy/masroofy/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.9" }
    },
    {
      "src": "masroofy/manage.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "masroofy/masroofy/wsgi.py"
    }
  ]
}