@startuml
skinparam shadowed false
skinparam backgroundColor #F1E5E8

skinparam state {
  BackgroundColor #1D5D74 
  BorderColor #1D5D74
  FontColor #FFFFFF
  FontSize 12
  RoundCorner 10
}

skinparam arrow {
  Color #D66D55
  FontColor #333333
  Thickness 2
}

skinparam Note {
  BackgroundColor #97B1C0
  BorderColor #1D5D74
}

[*] --> Initializing

state Initializing {
  [*] --> InitializationView
  
  InitializationView : do / enterTotalAmount()
  InitializationView : do / chooseStartDate()
  InitializationView : do / chooseEndDate()
  
  InitializationView --> CreateCycle : onContinue()
  
  CreateCycle : do / calculateInitialDailyLimit()
  CreateCycle : do / saveToSQLite()
}

' الخروج الصح من الـ state الكبير
Initializing --> DashboardActive : cycleCreated()

state DashboardActive {
  [*] --> DashboardView
  
  DashboardView : entry / loadDashboard()
  DashboardView : entry / showDailyLimit()

  DashboardView --> ExpenseEntryView : addExpense()
  
  state ExpenseEntryView {
    [*] --> ProcessTransaction
    
    ProcessTransaction : do / enterAmount()
    ProcessTransaction : do / selectCategory()
    ProcessTransaction : do / validateAmount()
    ProcessTransaction : do / recordExpense()
    ProcessTransaction : do / saveToSQLite()
  }

  ExpenseEntryView --> RecalculateBudget : success
  
  state RecalculateBudget {
    [*] --> UpdateBudget
    
    UpdateBudget : do / recalculateDailyLimit()
    UpdateBudget : do / updateRemainingBalance()
    UpdateBudget : do / saveToSQLite()
    
    UpdateBudget --> CheckThreshold
    CheckThreshold : do / evaluateSpendingThreshold()
  }

  RecalculateBudget --> AlertUser : [spentPercentage >= 0.80]
  RecalculateBudget --> DashboardView : [else]

  state AlertUser #D66D55 {
    AlertUser : do / showSpendingAlert()
  }
  
  AlertUser --> DashboardView : dismiss()

  DashboardView --> StatisticsView : viewStatistics()
  
  state StatisticsView {
    StatisticsView : do / groupExpensesByCategory()
    StatisticsView : do / generatePieChartData()
  }
  
  StatisticsView --> DashboardView : back()
}

DashboardActive --> CycleEnded : isFinalDay()
CycleEnded --> [*]

' ----------- Notes for NFRs -----------

note right of DashboardView
Performance:
Updates < 1 second
end note

note bottom of DashboardActive
Data stored locally (SQLite)
Fully offline supported
end note

@enduml